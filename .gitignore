# --- process_checks additions (open-computer-verifer-planner) ---

# Documentation stays out of this repo by design -- PROJECT.md, checkpoints.md,
# catalog.md, CLAUDE.md, and every upstream README.md. Nothing at runtime reads
# a .md file (process_checks/runner/ only loads checkpoints.json), so this is
# safe for the executable pipeline; docs are tracked elsewhere.
*.md

# Graphify's generated repo map -- large generated artifacts (graph.json,
# graph.html, manifest.json, cache/), not source we author.
graphify-out/

# Our own run outputs (records, trajectories, screenshots) -- generated,
# analogous to the existing evaluation/runs exclusion above.
process_checks/runs/

logs/
